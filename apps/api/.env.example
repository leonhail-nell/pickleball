# PicklePlay API — environment variables
# Copy the REQUIRED ones into Railway (Variables tab). Leave optional ones unset to disable that feature.
# Local dev: copy this file to apps/api/.env and fill in values.

# ── required ─────────────────────────────────────────────────────────────────

# Postgres connection string. In production use the Neon "pooled" connection string.
# Local dev example: postgresql://pickleplay:pickleplay@localhost:5432/pickleplay
DATABASE_URL=postgresql://user:password@host:5432/pickleplay?sslmode=require

# Signs auth tokens — MUST be a long random string in production, stable across restarts.
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string

# The ONE web origin allowed to call the API and open live (Socket.IO) connections.
# Must match your deployed web URL exactly — https, no trailing slash.
WEB_ORIGIN=https://pickleplay.io

# ── provided by the host ─────────────────────────────────────────────────────
# Railway/Render inject PORT automatically. Only set it for local dev if 4000 is taken.
PORT=4000

# ── optional: card payments (Stripe) — leave blank to disable ────────────────
# https://dashboard.stripe.com/apikeys  (use a live key sk_live_… in production)
STRIPE_SECRET_KEY=

# ── optional: GCash / Maya (PayMongo) — leave blank to disable ───────────────
# https://dashboard.paymongo.com/developers
PAYMONGO_SECRET_KEY=

# ── optional: Google sign-in — leave blank to disable ────────────────────────
# Must match NEXT_PUBLIC_GOOGLE_CLIENT_ID on the web app.
GOOGLE_CLIENT_ID=
